# Required environment variables for INKINGI CREATIVE HUB
# Copy this file to .env.local and fill in your credentials

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/inkingi
NEXTAUTH_SECRET=replace-with-a-long-secret
NEXTAUTH_URL=http://localhost:3000

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM="INKINGI Creative Hub <no-reply@inkingi.rw>"
ADMIN_NOTIFICATION_EMAIL=niyodidie@gmail.com

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-key
CLOUDINARY_API_SECRET=your-cloudinary-secret
